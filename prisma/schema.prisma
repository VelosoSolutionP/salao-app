generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  passwordHash  String?
  image         String?
  role          Role      @default(CLIENT)
  active           Boolean   @default(true)
  blocked          Boolean   @default(false)           // manually blocked by MASTER
  trialExpires     DateTime?                           // null = no trial limit
  stripeCustomerId String?   @unique                   // Stripe Customer ID para cobranças de planos
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  colaborador      Colaborador?
  cliente          Cliente?
  salons           Salon[]
  notifConfig      NotifConfig?
  movimentosEstoque MovimentoEstoque[]
  pushSubscriptions PushSubscription[]
  redes            Rede[]

  @@map("users")
}

enum Role {
  MASTER
  OWNER
  BARBER
  CLIENT
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────
// SALON
// ─────────────────────────────────────────

model Salon {
  id         String     @id @default(cuid())
  ownerId    String
  name       String
  slug       String     @unique
  phone      String?
  address    String?
  city       String?
  logoUrl    String?
  coverUrl   String?
  brandColor String?  @default("#7c3aed")
  timezone   String     @default("America/Sao_Paulo")
  currency   String     @default("BRL")
  pixKey     String?
  pixKeyType PixKeyType?
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // Acesso de funcionários
  codigoConvite        String?   @unique  // código para funcionários se cadastrarem

  // Política de cancelamento
  cancelamentoHorasMinimo Int     @default(24)   // horas de antecedência mínima para cancelar
  multaValor           Decimal?  @db.Decimal(10,2) // valor da multa por cancelamento tardio/não comparecimento
  multaTipo            MultaTipo?                  // PERCENTUAL ou FIXO

  indicacaoId  String?    @unique
  indicacao    Indicacao? @relation(fields: [indicacaoId], references: [id])

  owner                User                  @relation(fields: [ownerId], references: [id])
  colaboradores        Colaborador[]
  servicos             Servico[]
  agendamentos         Agendamento[]
  transacoes           Transacao[]
  campanhas            Campanha[]
  horarios             HorarioSalon[]
  produtos             Produto[]
  contratos            ContratoSalao[]
  transformacoes       Transformacao[]
  comissoesColaborador ComissaoColaborador[]
  planosFidelidade     PlanoFidelidade[]
  clientesPlano        ClientePlano[]
  rede                 Rede?                 @relation(fields: [redeId], references: [id])
  redeId               String?
  representante        Representante?        @relation(fields: [representanteId], references: [id])
  representanteId      String?
  indicador            Indicador?            @relation(fields: [indicadorId], references: [id])
  indicadorId          String?

  @@map("salons")
}

// ─────────────────────────────────────────
// MASTER — PLATAFORMA
// ─────────────────────────────────────────

model ContratoSalao {
  id          String   @id @default(cuid())
  salonId     String
  salon       Salon    @relation(fields: [salonId], references: [id])
  valorMensal Decimal  @db.Decimal(10, 2)
  diaVencimento Int    @default(10)   // dia do mês para cobrar
  ativo       Boolean  @default(true)
  observacao  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pagamentos  PagamentoContrato[]

  @@map("contratos_salao")
}

model PagamentoContrato {
  id         String   @id @default(cuid())
  contratoId String
  contrato   ContratoSalao @relation(fields: [contratoId], references: [id])
  valor      Decimal  @db.Decimal(10, 2)
  referencia String   // "2025-04" = mês/ano
  vencimento      DateTime?
  pago            Boolean  @default(false)
  pagoEm          DateTime?
  notificado      Boolean  @default(false)
  mpPreferenciaId String?  // Mercado Pago preference ID
  linkPagamento   String?  // Checkout Pro URL
  mpPagamentoId   String?  // MP payment ID (from webhook)
  createdAt       DateTime @default(now())

  comissoes  Comissao[]

  @@map("pagamentos_contrato")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

model GastoPlataforma {
  id        String   @id @default(cuid())
  descricao String
  valor     Decimal  @db.Decimal(10, 2)
  categoria String   @default("Geral")
  data      DateTime @default(now())
  createdAt DateTime @default(now())

  @@map("gastos_plataforma")
}

// ─────────────────────────────────────────
// REVENDEDORES / INDICAÇÕES
// ─────────────────────────────────────────

model Revendedor {
  id         String   @id @default(cuid())
  nome       String
  email      String?
  telefone   String?
  codigo     String   @unique
  percentual Decimal  @db.Decimal(5, 2) @default(10)
  ativo      Boolean  @default(true)
  observacao String?
  createdAt  DateTime @default(now())

  indicacoes Indicacao[]
  comissoes  Comissao[]

  @@map("revendedores")
}

model Indicacao {
  id           String     @id @default(cuid())
  revendedorId String
  revendedor   Revendedor @relation(fields: [revendedorId], references: [id])
  status       String     @default("PENDENTE") // PENDENTE, CONVERTIDA
  createdAt    DateTime   @default(now())

  salon     Salon?
  comissoes Comissao[]

  @@map("indicacoes")
}

model Comissao {
  id           String    @id @default(cuid())
  revendedorId String
  revendedor   Revendedor @relation(fields: [revendedorId], references: [id])
  indicacaoId  String
  indicacao    Indicacao  @relation(fields: [indicacaoId], references: [id])
  pagamentoId  String
  pagamento    PagamentoContrato @relation(fields: [pagamentoId], references: [id])
  valor        Decimal   @db.Decimal(10, 2)
  percentual   Decimal   @db.Decimal(5, 2)
  ehBonus      Boolean   @default(false) // primeiros 2 contratos = 100%
  referencia   String
  pago         Boolean   @default(false)
  pagoEm       DateTime?
  createdAt    DateTime  @default(now())

  @@map("comissoes")
}

// ─────────────────────────────────────────
// INDICADORES — pessoas avulsas que indicam
// ─────────────────────────────────────────

model Indicador {
  id                  String    @id @default(cuid())
  nome                String
  email               String?
  telefone            String?
  codigo              String    @unique  // código para link de indicação
  comissaoPorContrato Decimal   @db.Decimal(10, 2) @default(50)
  contratosBonus      Int       @default(2)
  observacao          String?
  ativo               Boolean   @default(true)
  createdAt           DateTime  @default(now())

  salons    Salon[]
  comissoes ComissaoIndicador[]

  @@map("indicadores")
}

model ComissaoIndicador {
  id          String    @id @default(cuid())
  indicadorId String
  indicador   Indicador @relation(fields: [indicadorId], references: [id])
  descricao   String    // ex: "Contrato #1 — Salão Bela"
  valor       Decimal   @db.Decimal(10, 2)
  ehBonus     Boolean   @default(false)
  referencia  String
  pago        Boolean   @default(false)
  pagoEm      DateTime?
  createdAt   DateTime  @default(now())

  @@map("comissoes_indicador")
}

// ─────────────────────────────────────────
// REPRESENTANTES — regiões exclusivas
// ─────────────────────────────────────────

model Representante {
  id         String    @id @default(cuid())
  nome       String
  email      String?
  telefone   String?
  regiao     String    // ex: "SP Capital", "SP Interior", "RJ", "Sul"
  percentual Decimal   @db.Decimal(5, 2) @default(10)
  observacao String?
  ativo      Boolean   @default(true)
  createdAt  DateTime  @default(now())

  salons    Salon[]
  comissoes ComissaoRepresentante[]

  @@map("representantes")
}

model ComissaoRepresentante {
  id              String        @id @default(cuid())
  representanteId String
  representante   Representante @relation(fields: [representanteId], references: [id])
  descricao       String
  valor           Decimal       @db.Decimal(10, 2)
  referencia      String
  pago            Boolean       @default(false)
  pagoEm          DateTime?
  createdAt       DateTime      @default(now())

  @@map("comissoes_representante")
}

enum PixKeyType {
  CPF
  CNPJ
  EMAIL
  PHONE
  RANDOM
}

enum MultaTipo {
  PERCENTUAL
  FIXO
}

model HorarioSalon {
  id        String  @id @default(cuid())
  salonId   String
  diaSemana Int
  abre      String
  fecha     String
  fechado   Boolean @default(false)

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, diaSemana])
  @@map("horarios_salon")
}

// ─────────────────────────────────────────
// STAFF
// ─────────────────────────────────────────

model Colaborador {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  salonId                String
  bio                    String?
  specialties            String[]
  comissao               Decimal  @default(0.40) @db.Decimal(5, 2)  // legado / fallback
  comissaoSalaoProduto   Decimal  @default(0.40) @db.Decimal(5, 2)  // usa produto do salão
  comissaoProprioProduto Decimal  @default(0.50) @db.Decimal(5, 2)  // usa produto próprio
  active                 Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  salon         Salon                   @relation(fields: [salonId], references: [id])
  agendamentos  Agendamento[]
  horarios      HorarioColaborador[]
  bloqueios     BloqueioAgenda[]
  servicosOffer ColaboradorServico[]
  comissoes     ComissaoColaborador[]

  @@map("colaboradores")
}

// ─────────────────────────────────────────
// COMISSÕES DE COLABORADOR
// ─────────────────────────────────────────

enum TipoProduto {
  PROPRIO  // profissional trouxe o produto
  SALAO    // produto do salão
}

model ComissaoColaborador {
  id            String      @id @default(cuid())
  salonId       String
  colaboradorId String
  agendamentoId String      @unique
  valor         Decimal     @db.Decimal(10, 2)
  percentual    Decimal     @db.Decimal(5, 2)
  tipoProduto   TipoProduto @default(SALAO)
  pago          Boolean     @default(false)
  pagoEm        DateTime?
  despesaId     String?     @unique             // DESPESA gerada ao pagar
  referencia    String                          // e.g. "Abril/2026"
  createdAt     DateTime    @default(now())

  salon       Salon        @relation(fields: [salonId], references: [id])
  colaborador Colaborador  @relation(fields: [colaboradorId], references: [id])
  agendamento Agendamento  @relation(fields: [agendamentoId], references: [id])
  despesa     Transacao?   @relation("ComissaoDespesa", fields: [despesaId], references: [id])

  @@index([salonId, pago])
  @@index([colaboradorId])
  @@map("comissoes_colaborador")
}

model HorarioColaborador {
  id            String  @id @default(cuid())
  colaboradorId String
  diaSemana     Int
  inicio        String
  fim           String
  ativo         Boolean @default(true)

  colaborador Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)

  @@unique([colaboradorId, diaSemana])
  @@map("horarios_colaborador")
}

model BloqueioAgenda {
  id            String   @id @default(cuid())
  colaboradorId String
  inicio        DateTime
  fim           DateTime
  motivo        String?

  colaborador Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)

  @@map("bloqueios_agenda")
}

// ─────────────────────────────────────────
// SERVICES
// ─────────────────────────────────────────

model Servico {
  id        String   @id @default(cuid())
  salonId   String
  nome      String
  descricao String?
  preco     Decimal  @db.Decimal(10, 2)
  duracao   Int
  categoria String?
  imageUrl  String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salon         Salon                @relation(fields: [salonId], references: [id])
  agendamentos  AgendamentoServico[]
  colaboradores ColaboradorServico[]

  @@map("servicos")
}

model ColaboradorServico {
  colaboradorId String
  servicoId     String
  precoCustom   Decimal? @db.Decimal(10, 2)

  colaborador Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  servico     Servico     @relation(fields: [servicoId], references: [id], onDelete: Cascade)

  @@id([colaboradorId, servicoId])
  @@map("colaborador_servico")
}

// ─────────────────────────────────────────
// CLIENTS
// ─────────────────────────────────────────

model Cliente {
  id           String    @id @default(cuid())
  userId       String    @unique
  salonId      String?
  cor          String?
  notas        String?   @db.Text
  dataNasc     DateTime?
  genero       String?
  totalGasto   Decimal   @default(0) @db.Decimal(10, 2)
  totalVisitas Int       @default(0)
  ultimaVisita DateTime?
  createdAt    DateTime  @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  agendamentos   Agendamento[]
  transformacoes Transformacao[]
  planosAtivos   ClientePlano[]

  @@map("clientes")
}

// ─────────────────────────────────────────
// APPOINTMENTS
// ─────────────────────────────────────────

model Agendamento {
  id                   String            @id @default(cuid())
  salonId              String
  clienteId            String?
  colaboradorId        String
  inicio               DateTime
  fim                  DateTime
  status               AgendamentoStatus @default(PENDENTE)
  observacoes          String?           @db.Text
  totalPrice           Decimal           @db.Decimal(10, 2)
  pagamento            MetodoPagamento?
  pagamentoStatus      PagamentoStatus   @default(PENDENTE)
  pixTxid                 String?
  stripePaymentIntentId   String?                          // PaymentIntent Stripe (legado)
  wooviCorrelationId      String?                          // Correlação Woovi PIX
  usouProprioProduto      Boolean           @default(false)  // profissional usou produto próprio?
  canceladoMotivo      String?
  canceladoPorCliente  Boolean           @default(false)   // cliente cancelou (vs. salão)
  multaAplicada        Boolean           @default(false)   // este agendamento gerou multa (cancelamento tardio/não comparecimento)
  multaValor           Decimal?          @db.Decimal(10,2) // valor da multa gerada
  multaPaga            Boolean           @default(false)   // multa foi cobrada no próximo agendamento
  lembrete1hEnviado    Boolean           @default(false)
  lembrete24hEnviado   Boolean           @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  salon       Salon                @relation(fields: [salonId], references: [id])
  cliente     Cliente?             @relation(fields: [clienteId], references: [id])
  colaborador Colaborador          @relation(fields: [colaboradorId], references: [id])
  servicos    AgendamentoServico[]
  transacao   Transacao?
  comissao    ComissaoColaborador?

  @@index([salonId, inicio])
  @@index([colaboradorId, inicio])
  @@index([clienteId])
  @@map("agendamentos")
}

model AgendamentoServico {
  agendamentoId String
  servicoId     String
  preco         Decimal @db.Decimal(10, 2)
  duracao       Int

  agendamento Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
  servico     Servico     @relation(fields: [servicoId], references: [id])

  @@id([agendamentoId, servicoId])
  @@map("agendamento_servico")
}

enum AgendamentoStatus {
  PENDENTE
  CONFIRMADO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
  NAO_COMPARECEU
}

enum MetodoPagamento {
  DINHEIRO
  CARTAO_CREDITO
  CARTAO_DEBITO
  PIX
  TRANSFERENCIA
}

enum PagamentoStatus {
  PENDENTE
  PAGO
  ESTORNADO
}

// ─────────────────────────────────────────
// FINANCIAL
// ─────────────────────────────────────────

model Transacao {
  id             String          @id @default(cuid())
  salonId        String
  agendamentoId  String?         @unique
  tipo           TipoTransacao
  descricao      String
  valor          Decimal         @db.Decimal(10, 2)
  metodo         MetodoPagamento?
  categoria      String?
  dataTransacao  DateTime        @default(now())
  comprovante    String?
  createdAt      DateTime        @default(now())

  salon       Salon                @relation(fields: [salonId], references: [id])
  agendamento Agendamento?         @relation(fields: [agendamentoId], references: [id])
  comissao    ComissaoColaborador? @relation("ComissaoDespesa")

  @@index([salonId, dataTransacao])
  @@map("transacoes")
}

enum TipoTransacao {
  RECEITA
  DESPESA
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model NotifConfig {
  id               String  @id @default(cuid())
  userId           String  @unique
  emailAtivo       Boolean @default(true)
  whatsappAtivo    Boolean @default(true)
  pushAtivo        Boolean @default(false)
  pushSubscription Json?
  lembrete1h       Boolean @default(true)
  lembrete24h      Boolean @default(true)
  lembreteConfirm  Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notif_configs")
}

// ─────────────────────────────────────────
// MARKETING
// ─────────────────────────────────────────

model Campanha {
  id           String       @id @default(cuid())
  salonId      String
  nome         String
  descricao    String?      @db.Text
  tipo         TipoCampanha
  desconto     Decimal?     @db.Decimal(5, 2)
  tipoDesconto TipoDesconto?
  codigo       String?      @unique
  validaDe     DateTime?
  validaAte    DateTime?
  ativa        Boolean      @default(true)
  usosMax      Int?
  usosAtuais   Int          @default(0)
  servicoIds   String[]
  createdAt    DateTime     @default(now())

  salon Salon @relation(fields: [salonId], references: [id])

  @@map("campanhas")
}

enum TipoCampanha {
  DESCONTO
  FIDELIDADE
  PRIMEIRO_AGENDAMENTO
  ANIVERSARIO
  PACOTE
}

enum TipoDesconto {
  PERCENTUAL
  FIXO
}

// ─────────────────────────────────────────
// ESTOQUE
// ─────────────────────────────────────────

model Produto {
  id          String   @id @default(cuid())
  salonId     String
  nome        String
  descricao   String?
  categoria   String?
  marca       String?
  unidade     String   @default("un")
  precoCompra Decimal? @db.Decimal(10, 2)
  precoVenda  Decimal? @db.Decimal(10, 2)
  estoque     Int      @default(0)
  estoqueMin  Int      @default(5)
  codigo      String?
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  salon      Salon              @relation(fields: [salonId], references: [id])
  movimentos MovimentoEstoque[]

  @@index([salonId])
  @@map("produtos")
}

model MovimentoEstoque {
  id         String        @id @default(cuid())
  produtoId  String
  tipo       TipoMovimento
  quantidade Int
  observacao String?
  userId     String
  createdAt  DateTime      @default(now())

  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@map("movimentos_estoque")
}

enum TipoMovimento {
  ENTRADA
  SAIDA
  AJUSTE
}

// ─────────────────────────────────────────
// TRANSFORMAÇÕES (ANTES & DEPOIS)
// ─────────────────────────────────────────

model Transformacao {
  id            String            @id @default(cuid())
  salonId       String
  clienteNome   String
  clienteId     String?
  tipo          TipoTransformacao
  fotoAntes     String?           // Vercel Blob URL
  fotoDepois    String?           // Vercel Blob URL
  colorimetria  Json?             // { marca, cor, oxidante, proporcao, notas }
  consentimento Boolean           @default(false)
  compartilhado Boolean           @default(false)
  observacao    String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  salon   Salon    @relation(fields: [salonId], references: [id])
  cliente Cliente? @relation(fields: [clienteId], references: [id])

  @@index([salonId])
  @@map("transformacoes")
}

enum TipoTransformacao {
  CABELO
  MAQUIAGEM
  UNHA
  COLORIMETRIA
}

// ─────────────────────────────────────────
// PLANOS DE FIDELIDADE (MENSAIS)
// ─────────────────────────────────────────

model PlanoFidelidade {
  id                  String              @id @default(cuid())
  salonId             String
  nome                String
  descricao           String?
  periodicidade       Periodicidade       @default(MENSAL)
  qtdAtendimentos     Int                 @default(1)   // atendimentos por período
  valor               Decimal             @db.Decimal(10, 2)
  servicoIds          String[]                          // serviços incluídos
  stripeProductId     String?                           // Product ID no Stripe
  stripePriceId       String?                           // Price ID no Stripe (recorrente)
  ativo               Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  salon         Salon          @relation(fields: [salonId], references: [id])
  clientesPlano ClientePlano[]

  @@index([salonId])
  @@map("planos_fidelidade")
}

model ClientePlano {
  id                     String   @id @default(cuid())
  salonId                String
  clienteId              String
  planoId                String
  dataInicio             DateTime
  dataFim                DateTime
  atendimentosUsados     Int      @default(0)
  // Stripe
  stripeSetupIntentId    String?
  stripePaymentMethodId  String?
  proximoVencimento      DateTime?
  ultimoPagamento        DateTime?
  pagamentoStatus        PagamentoStatus @default(PENDENTE)
  ativo                  Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  salon   Salon           @relation(fields: [salonId], references: [id])
  cliente Cliente         @relation(fields: [clienteId], references: [id])
  plano   PlanoFidelidade @relation(fields: [planoId], references: [id])

  @@index([salonId])
  @@index([clienteId])
  @@map("clientes_plano")
}

enum Periodicidade {
  SEMANAL
  QUINZENAL
  MENSAL
}

// ─────────────────────────────────────────
// REDE DE SALÕES (MULTI-UNIDADES)
// ─────────────────────────────────────────

model Rede {
  id        String   @id @default(cuid())
  ownerId   String
  nome      String
  logoUrl   String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner  User    @relation(fields: [ownerId], references: [id])
  salons Salon[]

  @@map("redes")
}
